# Required
SYNOLOGY_BASE_URL=https://your-nas-host:5001
SYNOLOGY_USERNAME=your-username
SYNOLOGY_PASSWORD=your-password

# Optional
SYNOLOGY_VERIFY_SSL=true
SYNOLOGY_TIMEOUT=30
SYNOLOGY_SESSION=FileStation

# Safety guards
SYNOLOGY_READONLY=false
# Optional allowlist (comma-separated). Keep empty for unrestricted writes.
# SYNOLOGY_MUTATION_ALLOW_PATHS=/home/ai-work
